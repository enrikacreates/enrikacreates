# Sanity — copy to .env.local and fill in with real values
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Tokens — never prefix with NEXT_PUBLIC_ (would leak to client)
SANITY_API_READ_TOKEN=sk...
SANITY_API_WRITE_TOKEN=sk...  # optional, only if you write from the server
